{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://crank.dev/infrastructure/vercel-project.schema.json",
  "title": "Vercel Project Declared State",
  "type": "object",
  "required": ["name", "framework"],
  "additionalProperties": false,
  "properties": {
    "name": { "type": "string" },
    "team": { "type": ["string", "null"] },
    "framework": { "enum": ["nextjs", "remix", "astro", "sveltekit", "other"] },
    "production_branch": { "type": "string", "default": "main" },
    "domains": { "type": "array", "items": { "type": "string" } },
    "env_var_refs": {
      "type": "array",
      "description": "Names of env vars set on the Vercel project. Values come from .env.local or the Vercel dashboard, not this file.",
      "items": {
        "type": "object",
        "required": ["name", "target"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "target": {
            "type": "array",
            "items": { "enum": ["production", "preview", "development"] }
          },
          "secret": { "type": "boolean", "default": true }
        }
      }
    },
    "analytics_enabled": { "type": "boolean", "default": true },
    "speed_insights_enabled": { "type": "boolean", "default": true }
  }
}
