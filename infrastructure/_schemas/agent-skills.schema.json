{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://crank.dev/infrastructure/agent-skills.schema.json",
  "title": "Agent Skills Declared State",
  "description": "Manifest of Claude Code skills, subagents, and slash commands that should exist under .claude/. The bootstrap layer asserts each one is present; missing ones are an install-failure.",
  "type": "object",
  "required": ["skills"],
  "additionalProperties": false,
  "properties": {
    "skills": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "purpose"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string", "description": "Slash-command name, e.g. layer-00-bootstrap." },
          "purpose": { "type": "string" },
          "layer_id": { "type": "string", "description": "Optional — set when this skill is a layer skill." },
          "shell": { "enum": ["powershell", "bash", "none"], "default": "powershell" },
          "disable_model_invocation": { "type": "boolean", "default": true }
        }
      }
    },
    "subagents": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "purpose"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "purpose": { "type": "string" }
        }
      }
    },
    "commands": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "purpose"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "purpose": { "type": "string" }
        }
      }
    }
  }
}
