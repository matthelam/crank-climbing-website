# Crank Scaffold — Local Secrets Template
#
# Copy this file to .env.local and fill in the values. .env.local is gitignored.
# Bootstrap layer (scripts/bootstrap.ps1) will prompt for any missing values.
#
# Source of truth for which secrets are required: infrastructure/secrets/policy.yaml

# Claude API key — required for orchestrator and most layers.
# Get one: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Vercel API token — required for hosting provisioning and deploy reads.
# Get one: https://vercel.com/account/tokens
VERCEL_TOKEN=

# GitHub token — only required if `gh auth login` cannot be used interactively.
# Get one: https://github.com/settings/tokens
GITHUB_TOKEN=
