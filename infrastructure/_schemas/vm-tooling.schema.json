{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://crank.dev/infrastructure/vm-tooling.schema.json",
  "title": "VM Tooling Declared State",
  "description": "CLIs and runtimes that must exist on the local Windows VM for the scaffold to operate. The bootstrap layer reads bindings.yaml install blocks plus this file to converge state.",
  "type": "object",
  "required": ["os", "tools"],
  "additionalProperties": false,
  "properties": {
    "os": {
      "type": "object",
      "required": ["family"],
      "additionalProperties": false,
      "properties": {
        "family": { "const": "windows" },
        "min_version": { "type": "string" }
      }
    },
    "tools": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "binding_capability"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "description": "Stable id for this tool entry." },
          "binding_capability": {
            "type": "string",
            "description": "Capability id in bindings.yaml whose install block governs this tool."
          },
          "required": { "type": "boolean", "default": true },
          "notes": { "type": "string" }
        }
      }
    }
  }
}
