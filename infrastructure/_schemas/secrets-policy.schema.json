{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://crank.dev/infrastructure/secrets-policy.schema.json",
  "title": "Secrets Policy",
  "description": "Declares what secrets the scaffold needs and where they live. Values are NEVER committed; this file declares names, locations, and whether a value is required for which layer to run.",
  "type": "object",
  "required": ["storage", "secrets"],
  "additionalProperties": false,
  "properties": {
    "storage": {
      "type": "object",
      "required": ["primary"],
      "additionalProperties": false,
      "properties": {
        "primary": { "enum": ["env_local_file"], "description": "v1 only supports a gitignored .env.local file at the repo root." },
        "path": { "type": "string", "default": ".env.local" },
        "template_path": { "type": "string", "default": ".env.local.example" }
      }
    },
    "secrets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "purpose", "required_for_layers"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string", "description": "Env var name, e.g. ANTHROPIC_API_KEY." },
          "purpose": { "type": "string" },
          "required_for_layers": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Layer ids that fail if this secret is missing."
          },
          "obtain_from_url": { "type": "string", "format": "uri", "description": "Where the user gets the value." }
        }
      }
    }
  }
}
